{
  "name": "micropython-k210-maixduino",
  "version": "0.1.0",
  "author": "ArthurZheng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openblock-plugin/microPythonK210Maixduino.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "npx openblock-registry-cli dev",
    "build": "npx openblock-registry-cli build",
    "build:obfuscate": "npx openblock-registry-cli build --obfuscate",
    "publish": "npx openblock-registry-cli publish",
    "publish:dry": "npx openblock-registry-cli publish --dry-run",
    "validate": "npx openblock-registry-cli validate",
    "i18n:update": "npx openblock-registry-cli i18n update",
    "lint": "eslint . --ext .js --fix"
  },
  "openblock": {
    "name": "K210 Maixduino",
    "deviceId": "microPythonK210Maixduino",
    "arch": [
      "microPython-k210-w"
    ],
    "manufactor": "kendryte",
    "learnMore": "https://wiki.sipeed.com/hardware/en/maix/maixduino/maixduino.html",
    "type": "microPython",
    "iconURL": "./assets/microPythonK210Maixduino.png",
    "description": {
      "formatMessage": {
        "id": "microPythonK210Maixduino.description",
        "default": "An Arduino-form K210 RISC-V AI development board with onboard Wi-Fi."
      }
    },
    "bluetoothRequired": false,
    "serialportRequired": true,
    "defaultBaudRate": "115200",
    "internetConnectionRequired": false,
    "launchPeripheralConnectionFlow": true,
    "useAutoScan": false,
    "connectionIconURL": "./assets/microPythonK210Maixduino-illustration.svg",
    "connectionSmallIconURL": "./assets/microPythonK210Maixduino-small.svg",
    "main": "./src/microPythonK210Maixduino.js",
    "generator": "./src/generator.js",
    "translations": "./src/translations.js",
    "programMode": [
      "upload"
    ],
    "tags": [
      "microPython"
    ],
    "helpLink": "https://wiki.openblock.cc/general-hardware-guidelines/boards/k210-maixduino",
    "firmwares": [
      {
        "id": "standard",
        "name": {
          "formatMessage": {
            "id": "microPythonK210Maixduino.firmware.standard",
            "default": "MaixPy Standard (kmodel V4)"
          }
        },
        "file": "./firmwares/maixpy_v0.6.3_2_gd8901fd22.bin"
      },
      {
        "id": "lvgl",
        "name": {
          "formatMessage": {
            "id": "microPythonK210Maixduino.firmware.lvgl",
            "default": "MaixPy with LVGL (kmodel V3)"
          }
        },
        "file": "./firmwares/maixpy_v0.6.3_2_gd8901fd22_with_lvgl.bin"
      }
    ],
    "examples": [
      {
        "id": "blink",
        "name": {
          "formatMessage": {
            "id": "microPythonK210Maixduino.examples.blink.name",
            "default": "Blink"
          }
        },
        "description": {
          "formatMessage": {
            "id": "microPythonK210Maixduino.examples.blink.description",
            "default": "Make the on-board LED blink."
          }
        },
        "file": "./examples/blink.ob"
      },
      {
        "id": "button",
        "name": {
          "formatMessage": {
            "id": "microPythonK210Maixduino.examples.button.name",
            "default": "Button"
          }
        },
        "description": {
          "formatMessage": {
            "id": "microPythonK210Maixduino.examples.button.description",
            "default": "Light up the LED while a push button is pressed."
          }
        },
        "file": "./examples/button.ob"
      },
      {
        "id": "fade",
        "name": {
          "formatMessage": {
            "id": "microPythonK210Maixduino.examples.fade.name",
            "default": "Fade"
          }
        },
        "description": {
          "formatMessage": {
            "id": "microPythonK210Maixduino.examples.fade.description",
            "default": "Smoothly fade an LED in and out using PWM."
          }
        },
        "file": "./examples/fade.ob"
      },
      {
        "id": "servoSweep",
        "name": {
          "formatMessage": {
            "id": "microPythonK210Maixduino.examples.servoSweep.name",
            "default": "Servo Sweep"
          }
        },
        "description": {
          "formatMessage": {
            "id": "microPythonK210Maixduino.examples.servoSweep.description",
            "default": "Sweep a servo back and forth between 0 and 180 degrees."
          }
        },
        "file": "./examples/servoSweep.ob"
      },
      {
        "id": "consolePrint",
        "name": {
          "formatMessage": {
            "id": "microPythonK210Maixduino.examples.consolePrint.name",
            "default": "Console Print"
          }
        },
        "description": {
          "formatMessage": {
            "id": "microPythonK210Maixduino.examples.consolePrint.description",
            "default": "Print messages to the terminal."
          }
        },
        "file": "./examples/consolePrint.ob"
      }
    ]
  },
  "devDependencies": {
    "babel-eslint": "^10.0.1",
    "eslint": "^5.3.0",
    "eslint-config-scratch": "^5.0.0",
    "husky": "^9.0.0"
  }
}
